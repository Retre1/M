# -------------------------------------------------------
# Broker: MetaTrader 5 (Windows only)
# -------------------------------------------------------
MT5_PATH=/path/to/terminal64.exe
MT5_LOGIN=12345678
MT5_PASSWORD=your_password
MT5_SERVER=YourBroker-Demo

# -------------------------------------------------------
# Broker: OANDA REST API v20 (cross-platform — Linux/macOS/Windows)
# Sign up free at https://www.oanda.com → practice account
# Generate token: My Services → Manage API Access
# -------------------------------------------------------
OANDA_API_TOKEN=your-oanda-api-token
OANDA_ACCOUNT_ID=your-account-id         # format: 001-001-1234567-001
OANDA_ENVIRONMENT=practice               # practice | live

# -------------------------------------------------------
# MLflow Experiment Tracking
# Set enabled: true in configs/base.yaml to activate.
# Then run: mlflow ui --backend-store-uri ./mlruns
# -------------------------------------------------------
MLFLOW_ENABLED=false
MLFLOW_TRACKING_URI=./mlruns

# Trading Configuration
TRADING_SYMBOL=EURUSD
INITIAL_BALANCE=100000

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# Dashboard
DASH_HOST=127.0.0.1
DASH_PORT=8050
DASH_DEBUG=false
