# =============================================================================
# ApexFX Quantum — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# --- MetaTrader 5 (REQUIRED for live trading) ---
MT5_PATH=/path/to/terminal64.exe
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# --- Trading ---
TRADING_SYMBOL=EURUSD
INITIAL_BALANCE=100000

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs

# --- News Data (optional) ---
FINNHUB_API_KEY=

# --- Alerts: Telegram (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Alerts: Webhook — Slack, Discord, PagerDuty (optional) ---
ALERT_WEBHOOK_URL=

# --- Dashboard ---
DASH_HOST=127.0.0.1
DASH_PORT=8050
DASH_DEBUG=false

# --- Environment (production / staging / development) ---
ENVIRONMENT=production
